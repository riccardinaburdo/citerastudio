---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const servicesDir = path.join(process.cwd(), 'src/content/services');
  const files = fs.readdirSync(servicesDir).filter(f => f.endsWith('.json'));
  return files.map(f => {
    const data = JSON.parse(fs.readFileSync(path.join(servicesDir, f), 'utf-8'));
    return {
      params: { slug: data.slug },
      props: { service: data },
    };
  });
}

const { service } = Astro.props;

function simpleMarkdown(text: string): string {
  return text
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/^  - (.+)$/gm, '<li class="indent">$1</li>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/\n\n/g, '</p><p>');
}

const htmlContent = simpleMarkdown(service.content);
---

<BaseLayout title={`Services - ${service.title} | citerastudio`} currentPath="/services">
  <div class="page-header">
    <h1>{service.title}</h1>
  </div>

  <div class="page-content service-detail">
    <Fragment set:html={htmlContent} />
  </div>

  {service.videoUrl && (
    <div class="video-container" style="max-width: 900px; margin: 2rem auto; padding: 0 2rem;">
      <video controls preload="metadata">
        <source src={service.videoUrl} type="video/mp4" />
      </video>
    </div>
  )}

  {service.gallery && service.gallery.length > 0 && (
    <div class="service-gallery">
      {service.gallery.map((img: {src: string; alt: string; caption?: string; description?: string}) => (
        <div class="service-gallery-item">
          <img src={img.src} alt={img.alt} class="gallery-clickable" />
          {img.caption && <h3>{img.caption}</h3>}
          {img.description && <p>{img.description}</p>}
        </div>
      ))}
    </div>
  )}

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&times;</button>
    <button class="lightbox-prev" id="lightbox-prev">&#10094;</button>
    <button class="lightbox-next" id="lightbox-next">&#10095;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>

  <script>
    const images = document.querySelectorAll('.gallery-clickable');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    let currentIndex = 0;
    const srcs = Array.from(images).map(img => (img as HTMLImageElement).src);

    function openLightbox(index: number) {
      currentIndex = index;
      lightboxImg.src = srcs[currentIndex];
      lightboxImg.alt = (images[currentIndex] as HTMLImageElement).alt;
      lightbox!.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox!.classList.remove('active');
      document.body.style.overflow = '';
    }

    images.forEach((img, i) => {
      img.addEventListener('click', () => openLightbox(i));
    });

    closeBtn!.addEventListener('click', closeLightbox);
    lightbox!.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    prevBtn!.addEventListener('click', (e) => {
      e.stopPropagation();
      currentIndex = (currentIndex - 1 + srcs.length) % srcs.length;
      lightboxImg.src = srcs[currentIndex];
    });

    nextBtn!.addEventListener('click', (e) => {
      e.stopPropagation();
      currentIndex = (currentIndex + 1) % srcs.length;
      lightboxImg.src = srcs[currentIndex];
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox!.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevBtn!.click();
      if (e.key === 'ArrowRight') nextBtn!.click();
    });
  </script>

  {service.subPages && service.subPages.length > 0 && (
    <div class="service-subpages-stack">
      {service.subPages.map((sub: {title: string; slug: string; image: string}) => (
        <a href={`/services/${sub.slug}`} class="service-banner" style={`background-image: url('${sub.image}')`}>
          <div class="service-banner-overlay">
            <h2>{sub.title}</h2>
            <span class="btn-view-more">View more</span>
          </div>
        </a>
      ))}
    </div>
  )}

  {service.downloadTitle && service.downloadUrl && (
    <div class="download-section">
      <h2>{service.downloadTitle}</h2>
      <a href={service.downloadUrl} class="btn-download" target="_blank" rel="noopener noreferrer">
        DOWNLOAD
      </a>
    </div>
  )}
</BaseLayout>
