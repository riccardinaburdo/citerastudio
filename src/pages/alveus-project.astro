---
import BaseLayout from '../layouts/BaseLayout.astro';
import alveus from '../content/pages/alveus.json';
---

<BaseLayout title="Alveus Project | citerastudio" currentPath="/alveus-project">
  <section class="alveus-hero">
    <h1>{alveus.title}</h1>
    <p>{alveus.subtitle}</p>
  </section>

  {alveus.videoUrl && (
    <div class="video-container" style="max-width: 600px; margin: 2rem auto;">
      <video controls preload="metadata" poster="">
        <source src={alveus.videoUrl} type="video/mp4" />
      </video>
    </div>
  )}

  <div class="page-content alveus-content">
    <h2 style="text-align: center;">Choose Earth, Ditch Plastic</h2>

    <p><strong>Forget about plastic materials!</strong></p>

    <p>The magic of outdoor thermal baths made with natural materials used by the ancient Egyptians and Romans, crafted with our exclusive technologies.</p>

    <p>We aim to help reconnect, through a design object, the deep bond that our bodies have lost with the earth, water, fire, and air.</p>

    <p>Our freestanding overflow tub offers water filtration, treatment, and recovery, infrared heating, and a relaxing bubble massage. It's a unique experience that will transport you back in time while you enjoy the ultimate modern comfort.</p>
  </div>
</BaseLayout>
