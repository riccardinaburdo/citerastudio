---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../content/pages/alveus-collection.json';
---

<BaseLayout title="Alveus Collection | citerastudio" currentPath="/alveus-project">
  <div class="page-header">
    <h1>{data.title}</h1>
  </div>

  <div class="page-content alveus-content">
    <ul class="features-list">
      {data.features.map((f) => (
        <li><strong>{f.label}:</strong> {f.text}</li>
      ))}
    </ul>
  </div>

  <div class="alveus-gallery">
    {data.gallery.map((item) => (
      <div class="gallery-item">
        <img src={item.src} alt={item.name} />
        <p>{item.name}</p>
      </div>
    ))}
  </div>

  <div class="alveus-subnav">
    <a href="/alveus-project/collection" class="active">Collection</a>
    <a href="/alveus-project/technology">Technology</a>
    <a href="/alveus-project/team">Team</a>
  </div>
</BaseLayout>
