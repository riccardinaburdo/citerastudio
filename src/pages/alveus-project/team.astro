---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../content/pages/alveus-team.json';
---

<BaseLayout title="Alveus Team | citerastudio" currentPath="/alveus-project">
  <div class="page-header">
    <h1>{data.title}</h1>
  </div>

  <div class="page-content alveus-content" style="text-align: center;">
    {data.intro.split('\n\n').map((p) => (
      <p>{p}</p>
    ))}
  </div>

  <div class="team-members">
    {data.members.map((member, i) => (
      <div class={`team-member ${i % 2 !== 0 ? 'reverse' : ''}`}>
        {i % 2 === 0 ? (
          <>
            <div class="team-photo">
              <img src={member.photo} alt={member.name} />
            </div>
            <div class="team-info">
              <h2>{member.name}</h2>
              <h3>{member.role}</h3>
              {member.bio.split('\n\n').map((p) => <p>{p}</p>)}
            </div>
          </>
        ) : (
          <>
            <div class="team-info">
              <h2>{member.name}</h2>
              <h3>{member.role}</h3>
              {member.bio.split('\n\n').map((p) => <p>{p}</p>)}
            </div>
            <div class="team-photo">
              <img src={member.photo} alt={member.name} />
            </div>
          </>
        )}
      </div>
    ))}
  </div>

  <div class="alveus-subnav">
    <a href="/alveus-project/collection">Collection</a>
    <a href="/alveus-project/technology">Technology</a>
    <a href="/alveus-project/team" class="active">Team</a>
  </div>
</BaseLayout>
