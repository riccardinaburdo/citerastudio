---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../content/pages/alveus-technology.json';
---

<BaseLayout title="Alveus Technology | citerastudio" currentPath="/alveus-project">
  <div class="page-header">
    <h1>{data.title}</h1>
  </div>

  <section class="alveus-hero">
    <h2>Features</h2>
  </section>

  <div class="page-content alveus-content">
    <ul class="features-list">
      {data.features.map((f) => (
        <li><strong>{f.label}:</strong> {f.text}</li>
      ))}
    </ul>
  </div>

  <div class="page-content alveus-content alveus-materials">
    {data.materials.map((mat, i) => (
      <div class={`material-section ${i % 2 !== 0 ? 'reverse' : ''}`}>
        <div class="material-text">
          <h2>{mat.name}</h2>
          <p>{mat.description}</p>
        </div>
        <div class="material-image">
          <img src={mat.image} alt={mat.name} />
        </div>
      </div>
    ))}
  </div>

  <div class="alveus-subnav">
    <a href="/alveus-project/collection">Collection</a>
    <a href="/alveus-project/technology" class="active">Technology</a>
    <a href="/alveus-project/team">Team</a>
  </div>
</BaseLayout>
