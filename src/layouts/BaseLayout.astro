---
import navigation from '../content/pages/navigation.json';
import footer from '../content/pages/footer.json';
import '../styles/global.css';

interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="CiteraStudio - Landscape Architecture by Vito Depalo" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Jost:wght@300;400&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="site-brand">
      <a href="/">
        <div class="brand-name">citerastudio</div>
        <div class="brand-subtitle">Landscape Architecture</div>
      </a>
    </div>
  </header>

  <nav class="site-nav" id="site-nav">
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">&#9776;</button>
    <ul>
      {navigation.menu.map((item) => (
        <li>
          <a href={item.url} class={currentPath === item.url ? 'active' : ''}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>{footer.address1}</p>
    <p>{footer.address2}</p>
    <p>{footer.address3}</p>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('site-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        nav.classList.toggle('closed');
      });
    }
  </script>
</body>
</html>
